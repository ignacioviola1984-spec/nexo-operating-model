# Nexo Operating Model v3 - environment template.
# Copy to .env (never commit .env) and fill in. The system runs end to end with
# only ANTHROPIC_API_KEY and the bootstrap admin set. No cloud credentials exist.

# --- Claude (prose layer only; numbers are never produced by the model) ---
# A fresh key dedicated to Nexo. Required only when NEXO_USE_LLM=1.
ANTHROPIC_API_KEY=
NEXO_MODEL=claude-opus-4-8
# 1 = Claude drafts the Spanish prose; 0 = deterministic templates (offline, free).
NEXO_USE_LLM=0

# --- Bootstrap admin (the one allowed first-boot account; see `make bootstrap-admin`) ---
NEXO_BOOTSTRAP_ADMIN_USER=
NEXO_BOOTSTRAP_ADMIN_NAME=
NEXO_BOOTSTRAP_ADMIN_PASSWORD=

# --- Local store + backups (no cloud; this is the system of record) ---
# Defaults are fine; override only to relocate the local DuckDB store / backups.
# NEXO_STORE_PATH=nexo_os/data/store/nexo.duckdb
# NEXO_BACKUP_DIR=backups

# --- Auth session ---
# NEXO_SESSION_TTL_MINUTES=480
