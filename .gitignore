# Nexo runtime artifacts (generated; never committed). Paths are relative to the repo root.

# Secrets: the ANTHROPIC_API_KEY lives in <repo>/.env and is NEVER committed.
.env

# Shared-state + audit trail written at run time
nexo_state.json
audit_log.jsonl

# Python caches
__pycache__/
*.pyc

# Generated outputs (Excel exports, metrics history + reports). The demo cartera
# under data/ IS committed; everything generated under outputs/ is not.
outputs/*
!outputs/.gitkeep

# Real broker data - the synthetic demo cartera is committed, real client PII NEVER is.
data/cartera_real*.xlsx
data/*_real.xlsx
data/real/

# ---------------------------------------------------------------------------
# Nexo v3 (nexo_os/) runtime artifacts - local system of record, NEVER committed.
# ---------------------------------------------------------------------------
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# The local DuckDB snapshot store (active + archived snapshots, acciones, audit
# log, agent runs). This holds real broker data + PII once in production.
nexo_os/data/store/
# Local backups of the store (PII; keep off the repo, see SECURITY.md).
backups/
# The generated blank Excel template and any uploaded/real workbooks.
nexo_os/data/templates/*.xlsx
data/uploads/
# Generated synthetic test workbook IS committed (visibly fake PII); broken
# fixtures are committed too. Real uploads are not.

